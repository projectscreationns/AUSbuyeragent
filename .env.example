# Google Custom Search API (for listing scout)
GOOGLE_API_KEY=your-google-api-key
GOOGLE_CSE_ID=your-programmable-search-engine-id

# Google Maps (for commute/distance checks)
GOOGLE_MAPS_API_KEY=your-maps-api-key

# Anthropic API (optional, for scout_api.py fallback)
ANTHROPIC_API_KEY=your-anthropic-key

# Domain API (not currently used — free tier lacks search)
DOMAIN_API_KEY=your-domain-key
